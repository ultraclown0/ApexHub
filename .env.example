# ApexHub — переменные окружения. Скопируйте в .env и заполните.
# .env в git НЕ попадает (см. .gitignore). Секреты только здесь, не в коде.

# --- База данных (Neon Postgres) ---
# Строка подключения из дашборда Neon (используйте pooled-эндпоинт для Vercel).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Админка (/admin), Basic Auth ---
# Без ADMIN_PASSWORD доступ к /admin закрыт (401).
ADMIN_USER="admin"
ADMIN_PASSWORD=""

# --- Источники данных (воркер ингеста: npm run ingest) ---
# Воркер пропускает источник, если его ключ не задан.

# DGS «Ingram» Tournament API — основной источник турнирной статистики.
# Токен самообслуживаемый: зарегистрируйтесь на apexlegendsstatus.com/tournament
# и скопируйте токен из Profile Settings (/tournament/profile). Бесплатно для некоммерции.
DGS_API_TOKEN=""
# DGS_API_BASE=""   # опционально: переопределить базовый URL

# Liquipedia LPDB — каталог турниров/команд/игроков + ссылки на стримы
LIQUIPEDIA_API_KEY=""
# LIQUIPEDIA_API_BASE=""   # опционально

# Twitch — проверка статуса «в эфире» (npm run ingest:twitch)
# Получить: dev.twitch.tv → Console → Register Your Application → Client ID/Secret
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""
